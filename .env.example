# Quant Research MCP local environment template.
# Copy to .env and fill secrets locally only. Do not commit .env.

APP_NAME=quant-research-mcp
ENVIRONMENT=dev
LOG_LEVEL=INFO

DATA_DIR=data
ARTIFACT_DIR=artifacts

MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
MCP_TRANSPORT=stdio

# Kraken public data should stay on REST for scheduled historical candles.
# WebSocket public data can be added later for real-time paper monitoring.
KRAKEN_REST_BASE_URL=https://api.kraken.com
KRAKEN_WS_PUBLIC_URL=wss://ws.kraken.com/v2
KRAKEN_WS_AUTH_URL=wss://ws-auth.kraken.com/v2

# Leave live trading disabled until validation and paper-evidence gates are wired.
ENABLE_LIVE_TRADING=false
REQUIRE_EXPLICIT_LIVE_MODE=true
ALLOWED_LIVE_SYMBOLS=["BTC/USD","SOL/USD"]
MAX_LIVE_ALLOCATION_PCT=0.02
MAX_SINGLE_TRADE_RISK_PCT=0.01

# Create a restricted Kraken API key. For research-only work, leave these blank.
# For future private WebSocket use, enable Kraken's WebSocket interface permission.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
